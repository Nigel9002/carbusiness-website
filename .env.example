# ============================================================
# MOTO KENYA - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!
# ============================================================

# ============================================================
# IMAGEKIT CONFIGURATION
# ============================================================
# Required for image upload functionality
# Get these from: https://imagekit.io/dashboard

IMAGEKIT_PUBLIC_KEY=public_your_public_key_here
IMAGEKIT_PRIVATE_KEY=private_your_private_key_here
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ============================================================
# FIREBASE CONFIGURATION
# ============================================================
# Required for Firestore database and authentication
# Get these from: Firebase Console > Project Settings > General

FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# SERVER CONFIGURATION
# ============================================================

# Port for the local server (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV=development

# ============================================================
# SECURITY & AUTHENTICATION
# ============================================================

# JWT Secret for session management (generate a strong secret)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# CSRF Token secret (generate a strong secret)
# Generate with: node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
CSRF_SECRET=your_csrf_secret_key_here

# Session timeout in minutes (default: 30)
SESSION_TIMEOUT=30

# ============================================================
# RATE LIMITING
# ============================================================

# Maximum requests per IP per minute (default: 30)
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_MS=60000

# ============================================================
# CORS CONFIGURATION
# ============================================================

# Allowed origins (comma separated)
# Add your production domains here
ALLOWED_ORIGINS=https://nige19002.github.io,http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500,https://caradds-227e9.web.app,https://caradds-227e9.firebaseapp.com

# ============================================================
# ADMIN CONFIGURATION
# ============================================================

# Super Admin emails (comma separated)
# These users will have full access to the system
SUPER_ADMIN_EMAILS=your-email@gmail.com,another-admin@example.com

# ============================================================
# WHATSAPP CONFIGURATION
# ============================================================

# WhatsApp business number (international format, no +)
WHATSAPP_NUMBER=254712345678

# ============================================================
# OPTIONAL: DEPLOYMENT ENVIRONMENTS
# ============================================================

# Firebase project for deployment
FIREBASE_PROJECT=caradds-227e9

# ============================================================
# OPTIONAL: FEATURE FLAGS
# ============================================================

# Enable/disable features
ENABLE_OFFLINE_SUPPORT=true
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_ANALYTICS=true

# ============================================================
# OPTIONAL: EMAIL CONFIGURATION
# ============================================================

# SMTP settings for email notifications (if needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@motokenya.com

# ============================================================
# OPTIONAL: MONITORING & DEBUGGING
# ============================================================

# Enable debug logging
DEBUG=false

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ============================================================
# OPTIONAL: PERFORMANCE
# ============================================================

# Maximum upload file size (in MB)
MAX_FILE_SIZE=10

# Image quality (1-100)
IMAGE_QUALITY=80

# ============================================================
# OPTIONAL: BACKUP
# ============================================================

# Enable automatic backups
ENABLE_BACKUPS=false

# Backup frequency (in hours)
BACKUP_INTERVAL=24

# ============================================================
# OPTIONAL: MAINTENANCE
# ============================================================

# Put the site in maintenance mode
MAINTENANCE_MODE=false

# Maintenance message
MAINTENANCE_MESSAGE=We are currently performing maintenance. Please check back soon.