{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "*.md",
      "*.log",
      ".env",
      ".env.*"
    ],
    "rewrites": [
      {
        "source": "/imagekit-auth",
        "function": "imagekitAuth"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}